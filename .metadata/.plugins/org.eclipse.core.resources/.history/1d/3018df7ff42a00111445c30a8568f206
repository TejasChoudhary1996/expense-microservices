
package com.example.analytics.service;

import com.example.analytics.dto.Expense;

import org.springframework.http.HttpEntity;
import org.springframework.http.HttpHeaders;
import org.springframework.http.HttpMethod;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import java.util.*;
import java.util.stream.Collectors;

@Service
public class AnalyticsService {

    private final String URL = "http://localhost:8081/expenses";

    
    public List<Expense> getAllExpenses(String token) {

        RestTemplate rt = new RestTemplate();

        HttpHeaders headers = new HttpHeaders();
        headers.set("Authorization", "Bearer " + token);

        HttpEntity<?> entity = new HttpEntity<>(headers);

        ResponseEntity<Expense[]> response = rt.exchange(
                URL,
                HttpMethod.GET,
                entity,
                Expense[].class
        );

        return Arrays.asList(response.getBody());
    }
    

    public Double getTotal(String token) {
        return getAllExpenses(token).stream()
        		.filter(e -> e.getAmount() != null)
                .mapToDouble(Expense::getAmount)
                .sum();
    }

    public Double getMonthly(int month) {
        return getAllExpenses().stream()
        		.filter(e-> e.getExpenseDate() != null)
                .filter(e -> e.getExpenseDate().getMonthValue() == month)
                .mapToDouble(Expense::getAmount)
                .sum();
    }

    public Map<String, Double> categoryWise() {
        return getAllExpenses().stream()
                .collect(Collectors.groupingBy(
                        Expense::getCategory,
                        Collectors.summingDouble(Expense::getAmount)
                ));
    }

    public Map<String, Double> paymentWise() {
        return getAllExpenses().stream()
                .collect(Collectors.groupingBy(
                        Expense::getPaymentMethod,
                        Collectors.summingDouble(Expense::getAmount)
                ));
    }

    public Map<String, Double> monthlyCategory(int month) {
        return getAllExpenses().stream()
                .filter(e -> e.getExpenseDate().getMonthValue() == month)
                .collect(Collectors.groupingBy(
                        Expense::getCategory,
                        Collectors.summingDouble(Expense::getAmount)
                ));
    }
}
