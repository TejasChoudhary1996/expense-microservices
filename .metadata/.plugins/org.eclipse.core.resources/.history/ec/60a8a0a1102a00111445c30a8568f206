<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>

<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Expense Tracker</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<%@ taglib prefix="c" uri="jakarta.tags.core"%>

<style>
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: #f4f6f9;
}

/* Sidebar */
.sidebar {
    width: 220px;
    height: 100vh;
    background: #1e3c72;
    color: white;
    position: fixed;
    padding: 20px;
}

/* Content */
.content {
    margin-left: 220px;
    padding: 20px;
}

/* Cards */
.card-box {
    background: white;
    padding: 20px;
    border-radius: 10px;
    margin-bottom: 20px;
}

/* Buttons */
.btn-primary {
    background: #ff7a18;
    border: none;
}

canvas {
    max-height: 300px !important;
}
/* COLLAPSED SIDEBAR */
.sidebar.collapsed {
    width: 70px;
}

.sidebar.collapsed span {
    display: none;
}

/* CONTENT SHIFT */
.content {
    margin-left: 220px;
    transition: all 0.3s;
}

.content.expanded {
    margin-left: 70px;
}

/* DARK MODE */
body.dark {
    background: #121212;
    color: white;
}

body.dark .card-box {
    background: #1e1e1e;
    color: white;
}

body.dark .sidebar {
    background: #000;
}

body.dark input,
body.dark select {
    background: #2c2c2c;
    color: white;
    border: none;
}

</style>

<script>
function toggleSidebar() {
    document.querySelector(".sidebar").classList.toggle("collapsed");
}

function toggleTheme() {
    document.body.classList.toggle("dark");
}
</script>

</head>

<body>

<!-- HEADER BAR -->
<div style="margin-left:220px; padding:10px; background:white; display:flex; justify-content:space-between;">
    <h5>Expense Tracker</h5>
    <button onclick="toggleTheme()" class="btn btn-dark">🌙</button>
</div>