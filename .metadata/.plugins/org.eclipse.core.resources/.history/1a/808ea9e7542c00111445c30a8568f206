package com.example.expenseservice.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.example.expenseservice.entity.Category;
import com.example.expenseservice.entity.PaymentMethod;
import com.example.expenseservice.repository.CategoryRepository;
import com.example.expenseservice.repository.PaymentMethodRepository;

import jakarta.servlet.http.HttpServletRequest;

@RestController
@RequestMapping("/meta")
public class MetaController {

    @Autowired
    private CategoryRepository categoryRepo;

    @Autowired
    private PaymentMethodRepository paymentRepo;

    @GetMapping("/categories")
    public List<Category> getCategories(HttpServletRequest request) {
    	Long userId = (Long) request.getAttribute("userId");
        return categoryRepo.findByUserId(userId);
    }

    @PostMapping("/categories")
    public Category addCategory(@RequestBody Category c,HttpServletRequest request) {
    	Long userId = (Long) request.getAttribute("userId");
    	c.setUserId(userId);
        return categoryRepo.save(c);
    }

    @GetMapping("/payments")
    public List<PaymentMethod> getPayments(HttpServletRequest request) {
    	String userIdStr = request.getHeader("X-User-Id");
        if (userIdStr == null) {
            throw new RuntimeException("Unauthorized");
        }
        Long userId = Long.parseLong(userIdStr);
        return paymentRepo.findByUserId(userId);
    }

    @PostMapping("/payments")
    public PaymentMethod addPayment(@RequestBody PaymentMethod p,HttpServletRequest request) {
    	String userIdStr = request.getHeader("X-User-Id");
        if (userIdStr == null) {
            throw new RuntimeException("Unauthorized");
        }
        Long userId = Long.parseLong(userIdStr);
    	p.setUserId(userId);
        return paymentRepo.save(p);
    }
}