<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>

<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Expense Tracker</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<%@ taglib prefix="c" uri="jakarta.tags.core"%>

<style>
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: #f4f6f9;
}

/* ===== SIDEBAR ===== */
.sidebar {
    width: 220px;
    height: 100vh;
    background: #1e3c72;
    color: white;
    position: fixed;
    top: 0;
    left: 0;
    padding: 20px;
}

/* ===== HEADER ===== */
.header {
    position: fixed;
    top: 0;
    left: 220px;
    right: 0;
    height: 60px;
    background: white;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    border-bottom: 1px solid #eee;
    z-index: 1000;
}

/* Header title modern look */
.header h5 {
    margin: 0;
    font-weight: 600;
    font-size: 18px;
}

/* ===== CONTENT ===== */
.content {
    margin-left: 220px;
    margin-top: 60px;
    padding: 20px;
}

/* ===== CARD ===== */
.card-box {
    background: white;
    padding: 20px;
    border-radius: 10px;
    margin-bottom: 20px;
}

/* ===== BUTTON ===== */
.btn-primary {
    background: #ff7a18;
    border: none;
}

/* ===== SIDEBAR LINKS ===== */
.sidebar a {
    display: block;
    padding: 10px;
    margin: 10px 0;
    color: white;
    text-decoration: none;
    border-radius: 8px;
}

.sidebar a:hover {
    background: rgba(255,255,255,0.1);
}

.sidebar a.active {
    background: #ff7a18;
}

/* ===== COLLAPSE ===== */
.sidebar.collapsed {
    width: 70px;
}

.sidebar.collapsed span {
    display: none;
}

.content.expanded {
    margin-left: 70px;
}

.header.expanded {
    left: 70px;
}

/* ===== DARK MODE ===== */
body.dark {
    background: #121212;
    color: white;
}

/* FIX HEADER IN DARK MODE */
body.dark .header {
    background: #1e1e1e;
    color: white;
    border-bottom: 1px solid #333;
}

body.dark .card-box {
    background: #1e1e1e;
}

body.dark .sidebar {
    background: #000;
}

body.dark input,
body.dark select {
    background: #2c2c2c;
    color: white;
    border: none;
}

/* Inputs fix */
body.dark input::placeholder {
    color: #aaa;
}

canvas {
    max-height: 300px !important;
}
</style>

<script>
function toggleSidebar() {
    document.querySelector(".sidebar").classList.toggle("collapsed");
    document.querySelector(".content").classList.toggle("expanded");
    document.querySelector(".header").classList.toggle("expanded");
}

function toggleTheme() {
    document.body.classList.toggle("dark");
}
</script>

</head>

<body>

<!-- ===== SIDEBAR ===== -->
<div class="sidebar">
    <button onclick="toggleSidebar()" class="btn btn-light mb-3">☰</button>

    <a href="/" class="active">📋 <span>Dashboard</span></a>
    <a href="/expenses">📄 <span>Expenses</span></a>
    <a href="/analytics">📊 <span>Analytics</span></a>
</div>

<!-- ===== HEADER ===== -->
<div class="header">
    <h5>💸 Expense Tracker</h5>
    <button onclick="toggleTheme()" class="btn btn-dark">🌙</button>
</div>