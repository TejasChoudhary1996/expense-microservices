package com.example.uiservice.controller;

import org.springframework.http.*;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.client.HttpClientErrorException;
import org.springframework.web.client.RestTemplate;

import com.example.uiservice.entity.Category;
import com.example.uiservice.entity.Expense;
import com.example.uiservice.entity.PaymentMethod;
import com.example.uiservice.service.UIService;
import com.fasterxml.jackson.databind.ObjectMapper;

import jakarta.servlet.http.HttpSession;

import java.time.LocalDate;
import java.util.*;

@Controller
public class UIController {

	private final String EXPENSE_URL = "http://localhost:8081";
	private final String AUTH_URL = "http://localhost:8082/auth";
	private final String ANALYTICS_URL = "http://localhost:8083/analytics";

	private UIService uiService;

	public UIController(UIService uiService) {
		this.uiService = uiService;
	}

	// ✅ Helper to attach JWT
	private HttpEntity<?> getEntityWithToken(HttpSession session) {
		String token = (String) session.getAttribute("token");

		HttpHeaders headers = new HttpHeaders();
		headers.set("Authorization", "Bearer " + token);

		return new HttpEntity<>(headers);
	}

	// ✅ Home / Dashboard
	@GetMapping("/")
	public String home(Model model, HttpSession session) {

		String token = (String) session.getAttribute("token");
		if (token == null) {
			return "redirect:/login";
		}

		RestTemplate rt = new RestTemplate();
		

		try {
			Long userId = this.uiService.extractUserIdFromToken(token);
			List expenses = rt
					.exchange(EXPENSE_URL + "/expenses", HttpMethod.GET, getEntityWithToken(session), List.class)
					.getBody();

			List categories = rt
					.exchange(EXPENSE_URL + "/meta/categories", HttpMethod.GET, getEntityWithToken(session), List.class)
					.getBody();

			List payments = rt
					.exchange(EXPENSE_URL + "/meta/payments", HttpMethod.GET, getEntityWithToken(session), List.class)
					.getBody();

			 Map user = getUserDetails(session);
			 


			    RestTemplate rt = new RestTemplate();

			    HttpHeaders headers = new HttpHeaders();
			    headers.set("Authorization", "Bearer " + session.getAttribute("token"));

			    HttpEntity<?> entity = new HttpEntity<>(headers);

			    ResponseEntity<Map> response = rt.exchange(
			            "http://localhost:8082/auth/me",
			            HttpMethod.GET,
			            entity,
			            Map.class
			    );

			    return response.getBody();
			
			 
			 
			 System.out.println("user details "+user);
			
			model.addAttribute("expenses", expenses);
			model.addAttribute("categories", categories);
			model.addAttribute("payments", payments);
			
			//model.addAttribute("userId", userDetail.getUsername());
		} catch (HttpClientErrorException.Unauthorized e) {
			return "redirect:/login";
		}

		model.addAttribute("page", "dashboard");
		return "pages/dashboard";
	}

	// ✅ Save Expense
	@PostMapping("/save")
	public String save(@ModelAttribute Expense expense, HttpSession session) {

		if (session.getAttribute("token") == null) {
			return "redirect:/login";
		}

		RestTemplate rt = new RestTemplate();

		HttpHeaders headers = new HttpHeaders();
		headers.set("Authorization", "Bearer " + session.getAttribute("token"));

		HttpEntity<Expense> request = new HttpEntity<>(expense, headers);

		rt.exchange(EXPENSE_URL + "/expenses", HttpMethod.POST, request, String.class);

		return "redirect:/";
	}

	// ✅ Add Category
	@PostMapping("/addCategory")
	public String addCategory(@ModelAttribute Category category, HttpSession session) {

		RestTemplate rt = new RestTemplate();

		HttpEntity<Category> request = new HttpEntity<>(category,
				(HttpHeaders) getEntityWithToken(session).getHeaders());

		rt.exchange(EXPENSE_URL + "/meta/categories", HttpMethod.POST, request, String.class);

		return "redirect:/";
	}

	// ✅ Add Payment
	@PostMapping("/addPaymentMethod")
	public String addPaymentMethod(@ModelAttribute PaymentMethod paymentMethod, HttpSession session) {

		RestTemplate rt = new RestTemplate();

		HttpEntity<PaymentMethod> request = new HttpEntity<>(paymentMethod,
				(HttpHeaders) getEntityWithToken(session).getHeaders());

		rt.exchange(EXPENSE_URL + "/meta/payments", HttpMethod.POST, request, String.class);

		return "redirect:/";
	}

	// ✅ Expenses Page
	@GetMapping("/expenses")
	public String expenses(Model model, HttpSession session) {

		if (session.getAttribute("token") == null) {
			return "redirect:/login";
		}

		RestTemplate rt = new RestTemplate();

		Expense[] expenseArray = rt
				.exchange(EXPENSE_URL + "/expenses", HttpMethod.GET, getEntityWithToken(session), Expense[].class)
				.getBody();

		List<Expense> expenses = Arrays.asList(expenseArray);

		model.addAttribute("expenses", expenses);
		model.addAttribute("page", "expenses");

		return "pages/expenses";
	}

	// ✅ Analytics Page
	@GetMapping("/analytics")
	public String analytics(Model model, HttpSession session) {

		if (session.getAttribute("token") == null) {
			return "redirect:/login";
		}

		RestTemplate rt = new RestTemplate();
		int month = LocalDate.now().getMonthValue();

		Double total = rt.exchange(ANALYTICS_URL + "/total", HttpMethod.GET, getEntityWithToken(session), Double.class)
				.getBody();

		Double monthly = rt.exchange(ANALYTICS_URL + "/monthly?month=" + month, HttpMethod.GET,
				getEntityWithToken(session), Double.class).getBody();

		Map categoryData = rt
				.exchange(ANALYTICS_URL + "/category", HttpMethod.GET, getEntityWithToken(session), Map.class)
				.getBody();

		Map paymentData = rt
				.exchange(ANALYTICS_URL + "/payment", HttpMethod.GET, getEntityWithToken(session), Map.class).getBody();

		model.addAttribute("totalExpenses", total);
		model.addAttribute("monthlyExpenses", monthly);
		model.addAttribute("categoryAnalytics", categoryData);
		model.addAttribute("paymentAnalytics", paymentData);

		try {
			ObjectMapper mapper = new ObjectMapper();
			model.addAttribute("categoryAnalyticsJson", mapper.writeValueAsString(categoryData));
			model.addAttribute("paymentAnalyticsJson", mapper.writeValueAsString(paymentData));
		} catch (Exception e) {
			e.printStackTrace();
		}

		model.addAttribute("page", "analytics");
		return "pages/analytics";
	}

	// ✅ Login Page
	@GetMapping("/login")
	public String loginPage() {
		return "pages/login";
	}

	// ✅ Signup Page
	@GetMapping("/signup")
	public String signupPage() {
		return "pages/signup";
	}

	// ✅ Login API
	@PostMapping("/login")
	public String login(@RequestParam String username, @RequestParam String password, HttpSession session) {

		RestTemplate rt = new RestTemplate();

		Map<String, String> req = new HashMap<>();
		req.put("username", username);
		req.put("password", password);

		try {
			String token = rt.postForObject(AUTH_URL + "/login", req, String.class);
			System.out.println("Received token: " + token);
			session.setAttribute("token", token);

			return "redirect:/";

		} catch (Exception e) {
			return "pages/login";
		}
	}

	// ✅ Signup API
	@PostMapping("/signup")
	public String signup(@RequestParam String username, @RequestParam String password) {

		RestTemplate rt = new RestTemplate();

		Map<String, String> req = new HashMap<>();
		req.put("username", username);
		req.put("password", password);

		try {
			rt.postForObject(AUTH_URL + "/signup", req, String.class);
			return "redirect:/login";
		} catch (Exception e) {
			return "pages/signup";
		}
	}

	// ✅ Logout
	@GetMapping("/logout")
	public String logout(HttpSession session) {
		session.invalidate();
		return "redirect:/login";
	}
	
	private Map getUserDetails(HttpSession session) {}
}