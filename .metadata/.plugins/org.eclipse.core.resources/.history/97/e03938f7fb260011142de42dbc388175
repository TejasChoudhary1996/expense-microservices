
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<html>
<body>

<h2>Add Expense</h2>
<form action="save" method="post">
Amount: <input type="number" step="0.01" name="amount"/><br/>
Description: <input type="text" name="description"/><br/>
<button type="submit">Save</button>
</form>

<h2>Expenses</h2>
<table border="1">
<tr><th>ID</th><th>Amount</th><th>Description</th></tr>
<c:forEach var="e" items="${expenses}">
<tr>
<td>${e.id}</td>
<td>${e.amount}</td>
<td>${e.description}</td>
</tr>
</c:forEach>
</table>

</body>
</html>
