<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="jakarta.tags.core"%>
<!DOCTYPE html>
<html>
<head>
<title>Expense Dashboard</title>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: #f4f6f9;
    transition: 0.3s;
}

/* DARK MODE */
body.dark {
    background: #121212;
    color: white;
}

/* Sidebar */
.sidebar {
    width: 220px;
    height: 100vh;
    background: #1e3c72;
    color: white;
    position: fixed;
    padding: 20px;
    transition: all 0.3s;
}

.sidebar.collapsed {
    width: 70px;
}

.sidebar a {
    display: flex;
    align-items: center;
    margin: 15px 0;
    cursor: pointer;
    transition: 0.2s;
}

.sidebar a span {
    margin-left: 10px;
}

.sidebar.collapsed span {
    display: none;
}

.sidebar a.active {
    color: #ff7a18;
    font-weight: bold;
}

/* Content */
.content {
    margin-left: 220px;
    padding: 20px;
    transition: all 0.3s;
}

.content.expanded {
    margin-left: 70px;
}

/* Cards */
.card-box {
    background: white;
    padding: 20px;
    border-radius: 10px;
    margin-bottom: 20px;
}

/* Dark cards */
body.dark .card-box {
    background: #1e1e1e;
}

/* Mobile */
@media (max-width: 768px) {
    .sidebar {
        width: 70px;
    }
    .content {
        margin-left: 70px;
    }
}
</style>

<script>
function toggleSidebar() {
    document.querySelector(".sidebar").classList.toggle("collapsed");
    document.querySelector(".content").classList.toggle("expanded");
}

function showSection(id) {
    document.getElementById("expenseSection").style.display = "none";
    document.getElementById("analyticsSection").style.display = "none";

    document.getElementById(id).style.display = "block";

    document.querySelectorAll(".sidebar a").forEach(el => el.classList.remove("active"));
    event.target.classList.add("active");
}

function toggleTheme() {
    document.body.classList.toggle("dark");
}
</script>

</head>

<body>

<!-- Sidebar -->
<div class="sidebar">
    <button onclick="toggleSidebar()" class="btn btn-light mb-3">☰</button>

    <a onclick="showSection('expenseSection')" class="active">📋 <span>Expenses</span></a>
    <a onclick="showSection('analyticsSection')">📊 <span>Analytics</span></a>

    <hr>

    <button onclick="toggleTheme()" class="btn btn-light">🌙</button>
</div>

<!-- Content -->
<div class="content">

<!-- ================= EXPENSE ================= -->
<div id="expenseSection">

<h3>Expenses</h3>

<div class="card-box">
<form action="save" method="post" class="row g-3">

    <div class="col-md-3">
        <input name="amount" placeholder="Amount" class="form-control" required>
    </div>

    <div class="col-md-3">
        <input name="description" placeholder="Description" class="form-control" required>
    </div>

    <div class="col-md-2">
        <input type="date" name="date" class="form-control" required>
    </div>

    <div class="col-md-2">
        <select name="category" class="form-select">
            <c:forEach var="c" items="${categories}">
                <option>${c.name}</option>
            </c:forEach>
        </select>
    </div>

    <div class="col-md-2">
        <select name="paymentMethod" class="form-select">
            <c:forEach var="p" items="${payments}">
                <option>${p.name}</option>
            </c:forEach>
        </select>
    </div>

    <div class="col-12">
        <button class="btn btn-primary">Add</button>
    </div>

</form>
</div>

<div class="card-box">
<table class="table">
<tr>
<th>ID</th><th>Amount</th><th>Description</th><th>Date</th>
</tr>

<c:forEach var="e" items="${expenses}">
<tr>
<td>${e.id}</td>
<td>&#8377; ${e.amount}</td>
<td>${e.description}</td>
<td>${e.date}</td>
</tr>
</c:forEach>

</table>
</div>

</div>

<!-- ================= ANALYTICS ================= -->
<div id="analyticsSection" style="display:none;">

<h3>Analytics</h3>

<div class="row">

<div class="col-md-6">
<div class="card-box text-center">
<h5>Total</h5>
<h3>&#8377; ${totalAnalytics}</h3>
</div>
</div>

<div class="col-md-6">
<div class="card-box text-center">
<h5>Monthly</h5>
<h3>&#8377; ${monthlyAnalytics}</h3>
</div>
</div>

</div>

<!-- CHARTS -->
<div class="row">

    <div class="col-md-6">
        <div class="card-box">
            <h5>Category Chart</h5>
            <canvas id="categoryChart"></canvas>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card-box">
            <h5>Payment Chart</h5>
            <canvas id="paymentChart"></canvas>
        </div>
    </div>

</div>

</div>

</div>

<script>
/* Category Chart */
const categoryData = ${categoryAnalyticsJson};

const catLabels = Object.keys(categoryData);
const catValues = Object.values(categoryData);

new Chart(document.getElementById('categoryChart'), {
    type: 'pie',
    data: {
        labels: catLabels,
        datasets: [{
            data: catValues
        }]
    }
});

/* Payment Chart */
const paymentData = ${paymentAnalyticsJson};

const payLabels = Object.keys(paymentData);
const payValues = Object.values(paymentData);

new Chart(document.getElementById('paymentChart'), {
    type: 'bar',
    data: {
        labels: payLabels,
        datasets: [{
            data: payValues
        }]
    }
});
</script>

</body>
</html>